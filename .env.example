# Copia este archivo a `.env` y rellena los valores.
# Para GitHub Pages / `npm run build:pages`, las mismas NEXT_PUBLIC_* pueden ir en `.env.production`
# (Next.js las carga en build de producción; son públicas en el cliente).
# Cliente Firebase (misma pantalla: Firebase Console → Configuración del proyecto → Tus apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Admin (solo servidor / API routes). Consola → Configuración → Cuentas de servicio → Generar nueva clave privada (JSON)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Pega el valor de "private_key" del JSON (puede ser una sola línea con \n entre líneas)
FIREBASE_ADMIN_PRIVATE_KEY=

# URL del microservicio de predicción (FastAPI)
PREDICTOR_URL=http://127.0.0.1:8001/predict

# Opcional: URL pública del predictor (Render/Railway/etc.) para producción / GitHub Pages
NEXT_PUBLIC_PREDICTOR_URL=
