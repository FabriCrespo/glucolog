rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Perfil y subcolecciones del usuario
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /events/{eventId} {
        allow read, write: if isOwner(userId);
      }

      match /glucose_features/{featureId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Registros de glucosa: glucoseRecords/{uid}/records/{recordId}
    match /glucoseRecords/{userId}/records/{recordId} {
      allow read, write: if isOwner(userId);
    }
  }
}
